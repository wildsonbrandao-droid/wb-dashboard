<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Simulador B2B Atacado — WB Consultoria</title>
<style>
  :root {
    --navy: #0D1B2A;
    --navy2: #1a2d42;
    --blue: #2563EB;
    --blue-light: #3b82f6;
    --blue-dim: #1e3a5f;
    --green: #10b981;
    --green-dim: #064e3b;
    --red: #ef4444;
    --red-dim: #7f1d1d;
    --yellow: #f59e0b;
    --yellow-dim: #78350f;
    --orange: #f97316;
    --gray: #64748b;
    --gray-light: #94a3b8;
    --white: #f8fafc;
    --border: #1e3a5f;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--navy);
    color: var(--white);
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-size: 14px;
    line-height: 1.5;
    min-height: 100vh;
    padding: 24px;
  }

  /* ── HEADER ── */
  .header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }
  .header-icon {
    width: 44px; height: 44px;
    background: var(--blue-dim);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
  }
  .header h1 { font-size: 18px; font-weight: 700; color: var(--white); }
  .header p  { font-size: 12px; color: var(--gray-light); margin-top: 2px; }

  /* ── GRID ── */
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }

  /* ── CARD ── */
  .card {
    background: var(--navy2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
  }
  .card-title {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--gray-light);
    margin-bottom: 14px;
  }

  /* ── KPI CARDS ── */
  .kpi { text-align: center; padding: 16px; }
  .kpi .value { font-size: 26px; font-weight: 700; }
  .kpi .label { font-size: 11px; color: var(--gray-light); margin-top: 4px; }
  .kpi .delta { font-size: 12px; margin-top: 6px; font-weight: 600; }
  .kpi.green .value { color: var(--green); }
  .kpi.red   .value { color: var(--red); }
  .kpi.blue  .value { color: var(--blue-light); }
  .kpi.yellow .value { color: var(--yellow); }

  /* ── SECTION TITLE ── */
  .section { margin-bottom: 20px; }
  .section-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--blue-light);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* ── FORM ── */
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-group label { font-size: 11px; color: var(--gray-light); font-weight: 500; text-transform: uppercase; letter-spacing: .05em; }
  .form-group select,
  .form-group input {
    background: var(--navy);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--white);
    padding: 10px 12px;
    font-size: 14px;
    outline: none;
    transition: border-color .15s;
    width: 100%;
  }
  .form-group select:focus,
  .form-group input:focus { border-color: var(--blue); }
  .form-group .hint { font-size: 11px; color: var(--gray); }

  /* ── TOGGLE ── */
  .toggle-row {
    display: flex;
    gap: 0;
    background: var(--navy);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 16px;
  }
  .toggle-btn {
    flex: 1; padding: 10px 6px;
    background: transparent;
    border: none; color: var(--gray-light);
    font-size: 12px; font-weight: 500;
    cursor: pointer; transition: all .15s;
    text-align: center;
  }
  .toggle-btn.active {
    background: var(--blue);
    color: #fff;
    font-weight: 700;
  }

  /* ── RESULTS TABLE ── */
  .results-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .results-table th {
    background: var(--navy);
    color: var(--gray-light);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .06em;
    padding: 10px 12px;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }
  .results-table td {
    padding: 11px 12px;
    border-bottom: 1px solid #0f2035;
    vertical-align: middle;
  }
  .results-table tr:last-child td { border-bottom: none; }
  .results-table tr:hover td { background: rgba(37, 99, 235, .06); }

  .badge {
    display: inline-block;
    padding: 3px 8px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
  }
  .badge-green  { background: rgba(16,185,129,.15); color: #34d399; }
  .badge-yellow { background: rgba(245,158,11,.15);  color: #fbbf24; }
  .badge-red    { background: rgba(239,68,68,.15);   color: #f87171; }
  .badge-blue   { background: rgba(37,99,235,.15);   color: #93c5fd; }

  /* ── IMPACT BARS ── */
  .impact-bar-wrap { margin-top: 6px; }
  .impact-bar-row  { display: flex; align-items: center; gap: 10px; margin-bottom: 7px; font-size: 12px; }
  .impact-bar-label { width: 140px; color: var(--gray-light); flex-shrink: 0; }
  .impact-bar-track { flex: 1; height: 8px; background: var(--navy); border-radius: 4px; overflow: hidden; }
  .impact-bar-fill  { height: 100%; border-radius: 4px; transition: width .4s ease; }
  .impact-bar-val   { width: 70px; text-align: right; font-weight: 600; color: var(--white); }

  /* ── EQUATION BOX ── */
  .eq-box {
    background: var(--navy);
    border: 1px solid var(--blue-dim);
    border-radius: 10px;
    padding: 14px 18px;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 12px;
    color: #93c5fd;
    line-height: 2;
  }
  .eq-box .eq-line-dim  { color: var(--gray); }
  .eq-box .eq-line-hi   { color: var(--green); font-weight: 700; }
  .eq-box .eq-line-warn { color: var(--yellow); font-weight: 700; }

  /* ── ALERT BOX ── */
  .alert {
    border-radius: 10px;
    padding: 14px 16px;
    font-size: 13px;
    display: flex;
    gap: 10px;
    align-items: flex-start;
    margin-top: 14px;
  }
  .alert-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }
  .alert-green  { background: rgba(16,185,129,.1);  border: 1px solid rgba(16,185,129,.25); color: #6ee7b7; }
  .alert-yellow { background: rgba(245,158,11,.1);  border: 1px solid rgba(245,158,11,.25); color: #fde68a; }
  .alert-red    { background: rgba(239,68,68,.1);   border: 1px solid rgba(239,68,68,.25);  color: #fca5a5; }

  /* ── CENARIOS COMPARE ── */
  .cen-card {
    border-radius: 10px;
    padding: 16px;
    border: 1px solid var(--border);
  }
  .cen-card .cen-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; margin-bottom: 10px; }
  .cen-card .cen-price { font-size: 24px; font-weight: 700; }
  .cen-card .cen-vs    { font-size: 12px; margin-top: 4px; }
  .cen-card .cen-desc  { font-size: 11px; color: var(--gray-light); margin-top: 8px; border-top: 1px solid var(--border); padding-top: 8px; }
  .cen-atual  { background: rgba(239,68,68,.08);  border-color: rgba(239,68,68,.25); }
  .cen-a      { background: rgba(245,158,11,.08); border-color: rgba(245,158,11,.25); }
  .cen-b      { background: rgba(16,185,129,.08); border-color: rgba(16,185,129,.25); }
  .cen-floor  { background: rgba(37,99,235,.08);  border-color: rgba(37,99,235,.25);  }

  /* ── PONTO DE EQUILÍBRIO ── */
  .bep-highlight {
    background: linear-gradient(135deg, rgba(37,99,235,.15), rgba(16,185,129,.1));
    border: 1px solid var(--blue-dim);
    border-radius: 12px;
    padding: 20px;
    text-align: center;
  }
  .bep-highlight .bep-number { font-size: 40px; font-weight: 800; color: var(--blue-light); }
  .bep-highlight .bep-label  { font-size: 13px; color: var(--gray-light); margin-top: 6px; }
  .bep-highlight .bep-sub    { font-size: 12px; color: var(--green); margin-top: 4px; font-weight: 600; }

  /* ── DIVIDER ── */
  .divider { height: 1px; background: var(--border); margin: 20px 0; }

  /* ── NOTE ── */
  .note { font-size: 11px; color: var(--gray); margin-top: 10px; font-style: italic; }

  /* ── BTN ── */
  .btn {
    padding: 10px 20px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    transition: all .15s;
  }
  .btn-blue  { background: var(--blue);  color: #fff; }
  .btn-blue:hover { background: var(--blue-light); }
  .btn-ghost { background: transparent; border: 1px solid var(--border); color: var(--gray-light); }
  .btn-ghost:hover { border-color: var(--blue); color: var(--white); }

  /* ── RESPONSIVE ── */
  @media (max-width: 700px) {
    .grid-2, .grid-3, .grid-4, .form-row { grid-template-columns: 1fr; }
    body { padding: 14px; }
  }
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="header-icon">📦</div>
  <div>
    <h1>Simulador B2B Atacado — Análise de Viabilidade</h1>
    <p>Impacto de reduzir o preço de atacado a CMV + Imposto (8,72%) | Linha ITTs</p>
  </div>
</div>

<!-- ── SEÇÃO 1: SELEÇÃO DO PRODUTO ── -->
<div class="section">
  <div class="section-title">1. Selecione o Produto e o Cenário</div>
  <div class="card">
    <div class="form-row">
      <div class="form-group">
        <label>Produto</label>
        <select id="sel-produto" onchange="calcular()">
          <option value="0">Latas 269ml</option>
          <option value="1">Latões 473ml</option>
          <option value="2">Tônica 1L</option>
          <option value="3">Energético 2L</option>
        </select>
      </div>
      <div class="form-group">
        <label>Volume atual vendido por mês (unidades)</label>
        <input type="number" id="vol-atual" value="500" min="1" step="10" oninput="calcular()">
        <span class="hint">Quantidade que você vende hoje no atacado</span>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Fator de custo fixo (multiplicador)</label>
        <input type="number" id="fator-fixo" value="1.27" min="1" max="2" step="0.01" oninput="calcular()">
        <span class="hint">Atual: 1,27 | Meta de volume: 1,20</span>
      </div>
      <div class="form-group">
        <label>Volume esperado após redução de preço (%)</label>
        <input type="number" id="cresc-vol" value="35" min="0" max="300" step="5" oninput="calcular()">
        <span class="hint">Crescimento esperado em % com o novo preço</span>
      </div>
    </div>

    <div style="margin-top:4px;">
      <div class="form-group">
        <label>Cenário de variáveis</label>
      </div>
      <div class="toggle-row">
        <button class="toggle-btn active" onclick="setCen('atual',this)">Atual<br><span style="font-size:10px;opacity:.7">20,72% var.</span></button>
        <button class="toggle-btn" onclick="setCen('A',this)">Cen. A<br><span style="font-size:10px;opacity:.7">s/ buffer</span></button>
        <button class="toggle-btn" onclick="setCen('B',this)">Cen. B<br><span style="font-size:10px;opacity:.7">+ FOB direto</span></button>
        <button class="toggle-btn" onclick="setCen('C',this)">Cen. C<br><span style="font-size:10px;opacity:.7">Floor</span></button>
        <button class="toggle-btn" onclick="setCen('CMV',this)">CMV + Imp.<br><span style="font-size:10px;opacity:.7">só obrigatório</span></button>
      </div>
    </div>
  </div>
</div>

<!-- ── SEÇÃO 2: COMPARATIVO DE PREÇOS ── -->
<div class="section">
  <div class="section-title">2. Comparativo de Preços por Cenário</div>
  <div class="grid-4" style="gap:12px;">
    <div class="cen-card cen-atual">
      <div class="cen-label" style="color:#f87171;">🔴 Atual</div>
      <div class="cen-price" style="color:#f87171;" id="p-atual">—</div>
      <div class="cen-vs" id="gap-atual" style="color:var(--gray-light);"></div>
      <div class="cen-desc">Preço com 20,72% var + fator fixo</div>
    </div>
    <div class="cen-card cen-a">
      <div class="cen-label" style="color:#fbbf24;">🟡 Cen. A</div>
      <div class="cen-price" style="color:#fbbf24;" id="p-cA">—</div>
      <div class="cen-vs" id="gap-cA" style="color:var(--gray-light);"></div>
      <div class="cen-desc">s/ buffer (10%) — boleto/PIX</div>
    </div>
    <div class="cen-card cen-b">
      <div class="cen-label" style="color:#34d399;">🟢 Cen. B</div>
      <div class="cen-price" style="color:#34d399;" id="p-cB">—</div>
      <div class="cen-vs" id="gap-cB" style="color:var(--gray-light);"></div>
      <div class="cen-desc">+ FOB + venda direta (s/ frete/comissão)</div>
    </div>
    <div class="cen-card cen-floor">
      <div class="cen-label" style="color:#93c5fd;">🔵 CMV + Imp.</div>
      <div class="cen-price" style="color:#93c5fd;" id="p-cmv">—</div>
      <div class="cen-vs" id="gap-cmv" style="color:var(--gray-light);"></div>
      <div class="cen-desc">Só imposto obrigatório + fator fixo</div>
    </div>
  </div>
</div>

<!-- ── SEÇÃO 3: EQUAÇÃO DO PREÇO ── -->
<div class="section">
  <div class="section-title">3. Formação do Preço no Cenário Selecionado</div>
  <div class="grid-2">
    <div class="card">
      <div class="card-title">Fórmula Aplicada</div>
      <div class="eq-box" id="eq-box">—</div>
      <p class="note" id="eq-note"></p>
    </div>
    <div class="card">
      <div class="card-title">Decomposição (% sobre PV)</div>
      <div class="impact-bar-wrap" id="bars">—</div>
    </div>
  </div>
</div>

<!-- ── SEÇÃO 4: IMPACTO FINANCEIRO ── -->
<div class="section">
  <div class="section-title">4. Impacto Financeiro (Volume Atual vs. Novo Preço + Crescimento)</div>
  <div class="grid-4">
    <div class="card kpi blue">
      <div class="value" id="kpi-preco-novo">—</div>
      <div class="label">Preço no cenário selecionado</div>
    </div>
    <div class="card kpi" id="kpi-mc-card">
      <div class="value" id="kpi-mc">—</div>
      <div class="label">MC unitária (R$)</div>
      <div class="delta" id="kpi-mc-delta"></div>
    </div>
    <div class="card kpi" id="kpi-fat-card">
      <div class="value" id="kpi-fat">—</div>
      <div class="label">Fat. mensal c/ crescimento</div>
      <div class="delta" id="kpi-fat-delta"></div>
    </div>
    <div class="card kpi" id="kpi-res-card">
      <div class="value" id="kpi-res">—</div>
      <div class="label">Resultado total mensal</div>
      <div class="delta" id="kpi-res-delta"></div>
    </div>
  </div>
</div>

<!-- ── SEÇÃO 5: PONTO DE EQUILÍBRIO ── -->
<div class="section">
  <div class="section-title">5. Ponto de Equilíbrio — Volume Mínimo para Manter Resultado</div>
  <div class="grid-2">
    <div class="bep-highlight">
      <div class="bep-number" id="bep-vol">—</div>
      <div class="bep-label">unidades/mês para manter o mesmo resultado líquido</div>
      <div class="bep-sub" id="bep-cresc">—</div>
    </div>
    <div class="card">
      <div class="card-title">Análise de Viabilidade</div>
      <div id="viabilidade-content">—</div>
    </div>
  </div>
</div>

<!-- ── SEÇÃO 6: IMPACTO NA DRE ── -->
<div class="section">
  <div class="section-title">6. Impacto Estimado na DRE Mensal (base: R$ 148k fat. médio)</div>
  <div class="card">
    <table class="results-table">
      <thead>
        <tr>
          <th>Item DRE</th>
          <th>Atual</th>
          <th>Cenário Selecionado (s/ crescimento)</th>
          <th>Cenário Selecionado (c/ crescimento)</th>
          <th>Variação</th>
        </tr>
      </thead>
      <tbody id="dre-tbody">
        <tr><td colspan="5" style="color:var(--gray);padding:20px;text-align:center;">Selecione um produto e cenário acima</td></tr>
      </tbody>
    </table>
    <p class="note">* DRE estimada com base no faturamento médio histórico de R$ 148k/mês. Participação do SKU selecionado calculada proporcionalmente ao volume informado.</p>
  </div>
</div>

<script>
// ── DADOS DOS PRODUTOS (NF 4514) ──────────────────────────────────────────────
const PRODUTOS = [
  { nome: 'Latas 269ml',   cmv: 4.2655, pi: 4.30 },
  { nome: 'Latões 473ml',  cmv: 5.3511, pi: 5.30 },
  { nome: 'Tônica 1L',     cmv: 4.6602, pi: 4.70 },
  { nome: 'Energético 2L', cmv: 4.8722, pi: 4.80 },
];

// ── COMPONENTES VARIÁVEIS ─────────────────────────────────────────────────────
const IMP   = 0.0872;  // imposto venda (obrigatório)
const FRETE = 0.02;
const DESC  = 0.10;
const COM   = 0.02;    // comissão (já zerada na NF 4514)
const DANOS = 0.01;
const MARG  = 0.03;

// Variáveis por cenário (sobre PV, sem fixo)
const CENS = {
  atual: { var: IMP + FRETE + DESC,          label: 'Atual — 20,72% var.' },
  A:     { var: IMP + FRETE,                  label: 'Cen. A — s/ buffer' },
  B:     { var: IMP,                           label: 'Cen. B — FOB + direto' },
  C:     { var: IMP + 0.005,                   label: 'Cen. C — floor' },
  CMV:   { var: IMP,                           label: 'CMV + Imposto' },
};

let cenAtual = 'atual';

function setCen(cen, btn) {
  cenAtual = cen;
  document.querySelectorAll('.toggle-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  calcular();
}

function R(v) { return 'R$ ' + v.toFixed(2).replace('.', ','); }
function Pct(v) { return (v*100).toFixed(1).replace('.', ',') + '%'; }
function N(v) { return v.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, '.'); }

function calcPV(cmv, varPct, fator) {
  return (cmv / (1 - varPct)) * fator;
}

function calcular() {
  const idx      = parseInt(document.getElementById('sel-produto').value);
  const volAtual = parseFloat(document.getElementById('vol-atual').value) || 0;
  const fator    = parseFloat(document.getElementById('fator-fixo').value) || 1.27;
  const crescPct = parseFloat(document.getElementById('cresc-vol').value) || 0;

  const prod = PRODUTOS[idx];
  const cmv  = prod.cmv;
  const pi   = prod.pi;

  // Preços de cada cenário
  const pAtual = calcPV(cmv, CENS.atual.var, fator);
  const pA     = calcPV(cmv, CENS.A.var,     fator);
  const pB     = calcPV(cmv, CENS.B.var,     fator);
  const pCMV   = calcPV(cmv, CENS.CMV.var,   fator);

  // Exibir cards de preço
  function gapLabel(pv) {
    const g = pv - pi;
    const pct = (pv/pi - 1)*100;
    const sign = g >= 0 ? '+' : '';
    return `${sign}R$ ${Math.abs(g).toFixed(2).replace('.',',')} vs indústria (${sign}${pct.toFixed(0)}%)`;
  }
  document.getElementById('p-atual').textContent = R(pAtual);
  document.getElementById('p-cA').textContent    = R(pA);
  document.getElementById('p-cB').textContent    = R(pB);
  document.getElementById('p-cmv').textContent   = R(pCMV);
  document.getElementById('gap-atual').textContent = gapLabel(pAtual);
  document.getElementById('gap-cA').textContent    = gapLabel(pA);
  document.getElementById('gap-cB').textContent    = gapLabel(pB);
  document.getElementById('gap-cmv').textContent   = gapLabel(pCMV);

  // Preço do cenário selecionado
  const varSel = CENS[cenAtual].var;
  const pvSel  = calcPV(cmv, varSel, fator);

  // MC unitária
  const mcAtualUn = pAtual - cmv - CENS.atual.var * pAtual;
  const mcSelUn   = pvSel  - cmv - varSel * pvSel;
  const fatAtual  = pAtual * volAtual;
  const volNovo   = volAtual * (1 + crescPct / 100);
  const fatNovo   = pvSel * volNovo;
  const resAtual  = mcAtualUn * volAtual;
  const resNovo   = mcSelUn   * volNovo;

  // KPIs
  document.getElementById('kpi-preco-novo').textContent = R(pvSel);

  const mcCard = document.getElementById('kpi-mc-card');
  document.getElementById('kpi-mc').textContent = R(mcSelUn);
  document.getElementById('kpi-mc-delta').textContent =
    (mcSelUn >= mcAtualUn ? '▲' : '▼') + ' ' + R(Math.abs(mcSelUn - mcAtualUn)) + ' vs atual';
  mcCard.className = 'card kpi ' + (mcSelUn >= mcAtualUn ? 'green' : 'red');

  const fatCard = document.getElementById('kpi-fat-card');
  document.getElementById('kpi-fat').textContent = 'R$ ' + N(fatNovo);
  document.getElementById('kpi-fat-delta').textContent =
    (fatNovo >= fatAtual ? '▲' : '▼') + ' R$ ' + N(Math.abs(fatNovo - fatAtual)) + ' vs atual';
  fatCard.className = 'card kpi ' + (fatNovo >= fatAtual ? 'green' : 'red');

  const resCard = document.getElementById('kpi-res-card');
  document.getElementById('kpi-res').textContent = 'R$ ' + N(resNovo);
  document.getElementById('kpi-res-delta').textContent =
    (resNovo >= resAtual ? '▲' : '▼') + ' R$ ' + N(Math.abs(resNovo - resAtual)) + ' vs atual';
  resCard.className = 'card kpi ' + (resNovo >= resAtual ? 'green' : 'red');

  // ── EQUAÇÃO ──────────────────────────────────────────────────────────────
  const nomes = {
    atual: ['CMV', 'Imposto (8,72%)', 'Frete (2%)', 'Buffer desc. (10%)'],
    A:     ['CMV', 'Imposto (8,72%)', 'Frete (2%)'],
    B:     ['CMV', 'Imposto (8,72%)'],
    C:     ['CMV', 'Imposto (8,72%)', 'Danos mín. (0,5%)'],
    CMV:   ['CMV', 'Imposto (8,72%)'],
  };
  const partes = nomes[cenAtual];
  const varPctFmt = (varSel * 100).toFixed(2).replace('.', ',');
  const fatorFmt  = fator.toFixed(2).replace('.', ',');
  const afFmt     = (cmv / (1 - varSel)).toFixed(4).replace('.', ',');

  document.getElementById('eq-box').innerHTML =
    `<span>P. Sugerido (AF)  = CMV ÷ (1 − ${varPctFmt}%)</span><br>` +
    `<span class="eq-line-dim">               = ${R(cmv).replace('R$ ','')} ÷ ${(1-varSel).toFixed(4).replace('.',',')} = R$ ${afFmt}</span><br>` +
    `<span>P. c/ Fixo  (AG)  = AF × ${fatorFmt}</span><br>` +
    `<span class="eq-line-hi">             = R$ ${afFmt} × ${fatorFmt} = ${R(pvSel)}</span><br>` +
    `<span class="eq-line-dim">Preço Indústria (ref.) = ${R(pi)}</span>`;

  document.getElementById('eq-note').textContent =
    `Componentes variáveis: ${partes.join(' + ')}`;

  // ── BARRAS ───────────────────────────────────────────────────────────────
  const cmvPct  = cmv / pvSel;
  const fixPct  = 1 - (1/fator);
  const varNoPv = varSel;
  const total   = cmvPct + fixPct + varNoPv;

  const barsData = [
    { label: 'CMV',          pct: cmvPct,  color: '#ef4444' },
    { label: `Variáveis (${(varNoPv*100).toFixed(1)}%)`, pct: varNoPv, color: '#f59e0b' },
    { label: `Fixo (fator)`, pct: fixPct,  color: '#f97316' },
  ];

  document.getElementById('bars').innerHTML = barsData.map(b =>
    `<div class="impact-bar-row">
      <span class="impact-bar-label">${b.label}</span>
      <div class="impact-bar-track">
        <div class="impact-bar-fill" style="width:${(b.pct*100).toFixed(1)}%;background:${b.color};"></div>
      </div>
      <span class="impact-bar-val">${Pct(b.pct)}</span>
    </div>`
  ).join('');

  // ── BEP ──────────────────────────────────────────────────────────────────
  const bepVol = mcAtualUn > 0
    ? Math.ceil(resAtual / mcSelUn)
    : 0;
  const bepCrPct = volAtual > 0
    ? ((bepVol - volAtual) / volAtual * 100).toFixed(0)
    : 0;

  document.getElementById('bep-vol').textContent = N(bepVol);
  document.getElementById('bep-cresc').textContent =
    bepVol > volAtual
      ? `+${bepCrPct}% acima do volume atual`
      : `Volume atual já é suficiente`;

  // Análise de viabilidade
  const viab = document.getElementById('viabilidade-content');
  let alerts = '';
  if (mcSelUn < 0) {
    alerts += `<div class="alert alert-red"><span class="alert-icon">🚨</span><div><strong>MC negativa no cenário selecionado.</strong> Cada unidade vendida gera prejuízo. Necessário aumentar o fator fixo ou revisar o cenário.</div></div>`;
  } else if (bepVol > volAtual * 2) {
    alerts += `<div class="alert alert-yellow"><span class="alert-icon">⚠️</span><div><strong>Crescimento necessário é alto (${bepCrPct}%).</strong> O volume mínimo para manter o resultado exige mais que dobrar as vendas deste SKU.</div></div>`;
  } else if (bepVol <= volAtual) {
    alerts += `<div class="alert alert-green"><span class="alert-icon">✅</span><div><strong>Viável sem crescimento adicional.</strong> O volume atual já cobre o resultado necessário no cenário selecionado.</div></div>`;
  } else {
    const crescNec = ((bepVol/volAtual - 1)*100).toFixed(0);
    alerts += `<div class="alert alert-yellow"><span class="alert-icon">📊</span><div><strong>Crescimento necessário: +${crescNec}%.</strong> Com +${crescNec}% de volume, o resultado se mantém. Você informou crescimento esperado de +${crescPct}% — ${crescPct >= crescNec ? '<span style="color:#34d399">suficiente ✓</span>' : '<span style="color:#f87171">insuficiente ✗</span>'}.</div></div>`;
  }
  if (pvSel <= pi + 0.50) {
    alerts += `<div class="alert alert-green"><span class="alert-icon">🎯</span><div><strong>Gap vs indústria muito baixo (${R(pvSel - pi)}).</strong> Neste cenário, o preço B2B é altamente competitivo frente à compra direta.</div></div>`;
  }
  viab.innerHTML = alerts || `<p style="color:var(--gray)">Selecione um cenário para ver a análise.</p>`;

  // ── DRE ──────────────────────────────────────────────────────────────────
  const fatMedTotal = 148000;
  const partSkuAtual = fatAtual;
  const partSkuNovo  = pvSel * volAtual;
  const partSkuCrsc  = fatNovo;

  const mcTotalAtual = resAtual;
  const mcTotalNovo  = mcSelUn * volAtual;
  const mcTotalCrsc  = resNovo;

  function dreRow(label, vAtual, vNovo, vCrsc, isCurrency = true, isPositiveGood = true) {
    const diff = vCrsc - vAtual;
    const sign = diff >= 0 ? '+' : '';
    const cls  = diff === 0 ? '' : (diff > 0) === isPositiveGood ? 'style="color:var(--green)"' : 'style="color:var(--red)"';
    const fmt  = isCurrency ? (v => 'R$ ' + N(v)) : (v => N(v) + ' un.');
    return `<tr>
      <td>${label}</td>
      <td>${fmt(vAtual)}</td>
      <td>${fmt(vNovo)}</td>
      <td>${fmt(vCrsc)}</td>
      <td ${cls}>${sign}${fmt(diff)}</td>
    </tr>`;
  }

  document.getElementById('dre-tbody').innerHTML =
    dreRow('Volume (unidades)', volAtual, volAtual, volNovo, false) +
    dreRow('Faturamento (SKU)', fatAtual, partSkuNovo, partSkuCrsc) +
    dreRow('CMV total', cmv * volAtual, cmv * volAtual, cmv * volNovo, true, false) +
    dreRow('MC total', mcTotalAtual, mcTotalNovo, mcTotalCrsc, true, true);
}

// Inicializar
calcular();
</script>

</body>
</html>
